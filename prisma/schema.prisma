generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

enum Role {
  admin
  karyawan
  mandor
}

enum Status {
  pending
  approved
}

model User {
  id           Int           @id @default(autoincrement())
  nid          String        @unique
  username     String
  password     String
  role         Role          @default(karyawan)
  createdAt      DateTime      @default(now())
  deletedAt      DateTime?
  failedAttempts Int           @default(0)
  lockedUntil    DateTime?
  transactions   Transaction[]
}

model Transaction {
  id        Int      @id @default(autoincrement())
  foto      String
  tempat    String
  waktu     DateTime
  status    Status   @default(pending)
  createdAt DateTime @default(now())
  deletedAt DateTime?
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  apdId     Int
  apd       Apd      @relation(fields: [apdId], references: [id], onDelete: Restrict)
}

model Apd {
  id           Int           @id @default(autoincrement())
  name         String
  stock        Int
  description  String?
  createdAt    DateTime      @default(now())
  deletedAt    DateTime?
  transactions Transaction[]
}